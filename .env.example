# Neon PostgreSQL (Vercel)
# Creá una base gratis en https://neon.tech/app
# Reemplazá estos valores con los tuyos

# Connection pooler (para Vercel/serverless - usar esta en producción)
DATABASE_URL="postgresql://usuario:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Direct connection (para migraciones/prisma db push desde local)
DIRECT_URL="postgresql://usuario:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
